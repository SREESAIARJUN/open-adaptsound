{
  "name": "open-adaptsound",
  "private": true,
  "version": "1.3.0",
  "description": "Personal hearing equalizer for Windows — beep test to system-wide EQ via Equalizer APO",
  "keywords": [
    "windows",
    "equalizer",
    "equalizer-apo",
    "hearing",
    "hearing-test",
    "personal-eq",
    "headphones",
    "system-wide-eq",
    "parametric-eq",
    "audiometry",
    "tauri"
  ],
  "homepage": "https://github.com/SREESAIARJUN/open-adaptsound#readme",
  "bugs": {
    "url": "https://github.com/SREESAIARJUN/open-adaptsound/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SREESAIARJUN/open-adaptsound.git"
  },
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build",
    "test:calc": "node --test src/calculator.test.js src/staircase.test.js",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test": "npm run test:calc && npm run test:rust",
    "check": "cargo check --manifest-path src-tauri/Cargo.toml"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}
